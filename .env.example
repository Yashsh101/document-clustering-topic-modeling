# Environment variables for document clustering project
# Copy to .env and set appropriate values

# Data configuration
DATA_INPUT_DIR=data/sample
DATA_OUTPUT_DIR=artifacts

# Preprocessing configuration
PREPROCESS_LOWERCASE=true
PREPROCESS_REMOVE_PUNCTUATION=true
PREPROCESS_REMOVE_NUMBERS=false
PREPROCESS_REMOVE_STOPWORDS=true
PREPROCESS_LEMMATIZE=true

# Vectorization configuration
VECTORIZER_MAX_FEATURES=500
VECTORIZER_MIN_DF=2
VECTORIZER_MAX_DF=0.95

# Clustering configuration
CLUSTERING_N_CLUSTERS=5
CLUSTERING_RANDOM_STATE=42
CLUSTERING_MAX_ITER=300

# Topic modeling configuration
TOPIC_N_TOPICS=5
TOPIC_MAX_ITER=20

# Logging
LOG_LEVEL=INFO
